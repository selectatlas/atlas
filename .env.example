# ── Required ────────────────────────────────────────────────────────────────
# Missing values fail server startup by name (src/instrumentation.ts).

# Supabase project URL and publishable (anon) key - safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only. NEVER prefix with NEXT_PUBLIC_ and never import into client
# components. CI verifies these values are absent from client bundles.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=your-openai-api-key

# ── Optional ────────────────────────────────────────────────────────────────

# Canonical site origin used for sitemap.xml, robots.txt, and Open Graph URLs.
# Set to the production domain when deploying (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostHog analytics (optional — app runs without these)
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# The local demo login button is enabled automatically by `npm run dev`.

# Comma-separated emails bootstrapped as platform admins (owner role) on sign-in.
# ATLAS_ADMIN_EMAILS=you@atlas.example
